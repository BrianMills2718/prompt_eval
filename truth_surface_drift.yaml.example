# Illustrative scaffold only. Replace all paths and rule patterns with real
# repo-local surfaces before running the validator.

version: 1

# Optional repo-local scope. Use canonical repo names, not worktree branch names.
# scope:
#   repo_names:
#     - your_repo_name

surfaces:
  tracker_file: docs/ops/ACTIVE_TRACKER.md
  registry_file: ~/.claude/coordination/active-work-registry.yaml
  plan_index_file: docs/plans/CLAUDE.md

checks:
  consumed_reservations_exist:
    severity: fail

  no_active_work_for_complete_plans:
    severity: fail

  # Optional explicit tracker-vs-registry contradiction rules.
  tracker_next_action_claim_conflicts:
    rules:
      - tracker_pattern: "create the .* worktree"
        project: your_repo_name
        scope: your-active-scope
        severity: fail

  # Optional claimed-text-vs-measured-audit parity rules.
  audit_claim_rules:
    rules:
      - source_pattern: "coordination adoption state: (?P<claim>\w+)"
        audit_file: generated/truth_surface_audit.json
        audit_json_path: repo_results.your_repo_name.coordination_adoption_state
        severity: fail
